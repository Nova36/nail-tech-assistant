{
  "color": {
    "brand": {
      "primary": { "$value": "#6B3F5E", "$type": "color" },
      "primary-tint": { "$value": "#D4A5A8", "$type": "color" },
      "accent": { "$value": "#C9A96E", "$type": "color" }
    },
    "neutral": {
      "foreground": { "$value": "#3D3530", "$type": "color" },
      "muted": { "$value": "#8C7E78", "$type": "color" },
      "light": { "$value": "#D4CBC5", "$type": "color" }
    },
    "surface": {
      "default": { "$value": "#FAF7F2", "$type": "color" },
      "raised": { "$value": "#F0EBE3", "$type": "color" }
    },
    "feedback": {
      "destructive": { "$value": "#C0595A", "$type": "color" }
    }
  },
  "gradient": {
    "signature": {
      "$value": "linear-gradient(135deg, #E8D5E0 0%, #C9B4C9 40%, #D4A8B0 70%, #E8C9A0 100%)",
      "$type": "gradient"
    }
  },
  "typography": {
    "font-family": {
      "heading": {
        "$value": "Fraunces, Georgia, serif",
        "$type": "fontFamily",
        "$extensions": {
          "design-system.self-hosted": {
            "manifest": "fonts/fonts.json",
            "family": "fraunces"
          }
        }
      },
      "body": {
        "$value": "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
        "$type": "fontFamily",
        "$extensions": {
          "design-system.self-hosted": {
            "manifest": "fonts/fonts.json",
            "family": "inter"
          }
        }
      }
    },
    "font-size": {
      "display": { "$value": "48px", "$type": "dimension" },
      "h1": { "$value": "36px", "$type": "dimension" },
      "h2": { "$value": "28px", "$type": "dimension" },
      "h3": { "$value": "22px", "$type": "dimension" },
      "h4": { "$value": "18px", "$type": "dimension" },
      "body-lg": { "$value": "17px", "$type": "dimension" },
      "base": { "$value": "15px", "$type": "dimension" },
      "body-sm": { "$value": "13px", "$type": "dimension" },
      "label": { "$value": "12px", "$type": "dimension" },
      "caption": { "$value": "11px", "$type": "dimension" }
    },
    "line-height": {
      "display": { "$value": "1.15", "$type": "number" },
      "h1": { "$value": "1.2", "$type": "number" },
      "h2": { "$value": "1.25", "$type": "number" },
      "h3": { "$value": "1.3", "$type": "number" },
      "h4": { "$value": "1.4", "$type": "number" },
      "body-lg": { "$value": "1.6", "$type": "number" },
      "base": { "$value": "1.65", "$type": "number" },
      "body-sm": { "$value": "1.6", "$type": "number" },
      "label": { "$value": "1.5", "$type": "number" },
      "caption": { "$value": "1.4", "$type": "number" }
    },
    "font-weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    }
  },
  "spacing": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "32px", "$type": "dimension" },
    "3xl": { "$value": "48px", "$type": "dimension" },
    "4xl": { "$value": "64px", "$type": "dimension" },
    "5xl": { "$value": "96px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "10px", "$type": "dimension" },
    "lg": { "$value": "20px", "$type": "dimension" },
    "xl": { "$value": "28px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": {
      "$value": "0 1px 3px rgba(61,53,48,0.08), 0 1px 2px rgba(61,53,48,0.04)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 12px rgba(61,53,48,0.10), 0 2px 4px rgba(61,53,48,0.06)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 8px 24px rgba(61,53,48,0.12), 0 4px 8px rgba(61,53,48,0.06)",
      "$type": "shadow"
    },
    "glow-primary": {
      "$value": "0 0 0 3px rgba(107,63,94,0.25)",
      "$type": "shadow"
    },
    "glow-accent": {
      "$value": "0 0 0 3px rgba(201,169,110,0.30)",
      "$type": "shadow"
    }
  },
  "size": {
    "touch-target-min": { "$value": "44px", "$type": "dimension" },
    "container-tablet-landscape": { "$value": "1180px", "$type": "dimension" },
    "container-tablet-portrait": { "$value": "820px", "$type": "dimension" }
  },
  "breakpoint": {
    "sm": { "$value": "640px", "$type": "dimension" },
    "md": { "$value": "768px", "$type": "dimension" },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" }
  },
  "shadcn": {
    "background": { "$value": "{color.surface.default}", "$type": "color" },
    "foreground": { "$value": "{color.neutral.foreground}", "$type": "color" },
    "card": { "$value": "{color.surface.raised}", "$type": "color" },
    "card-foreground": {
      "$value": "{color.neutral.foreground}",
      "$type": "color"
    },
    "primary": { "$value": "{color.brand.primary}", "$type": "color" },
    "primary-foreground": {
      "$value": "{color.surface.default}",
      "$type": "color"
    },
    "secondary": { "$value": "{color.surface.raised}", "$type": "color" },
    "secondary-foreground": {
      "$value": "{color.neutral.foreground}",
      "$type": "color"
    },
    "muted": { "$value": "{color.surface.raised}", "$type": "color" },
    "muted-foreground": { "$value": "{color.neutral.muted}", "$type": "color" },
    "accent": { "$value": "{color.brand.primary-tint}", "$type": "color" },
    "accent-foreground": {
      "$value": "{color.brand.primary}",
      "$type": "color"
    },
    "destructive": {
      "$value": "{color.feedback.destructive}",
      "$type": "color"
    },
    "destructive-foreground": {
      "$value": "{color.surface.default}",
      "$type": "color"
    },
    "border": { "$value": "{color.neutral.muted}", "$type": "color" },
    "input": { "$value": "{color.surface.raised}", "$type": "color" },
    "ring": { "$value": "{color.brand.primary}", "$type": "color" }
  }
}
