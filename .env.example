# Template — copy this to .env.local and fill in values.
# .env.local is gitignored; .env.example is committed.

# --- Pinterest (static-token approach) ---
# Generate in https://developers.pinterest.com/apps/ under your app's "Generate access token" feature.
# For single-user apps, a direct access token is sufficient; no OAuth flow is needed.
PINTEREST_APP_ID=
PINTEREST_ACCESS_TOKEN=

# --- Firebase ---
# All NEXT_PUBLIC_ values come from Firebase Console → Project Settings → General.
# Service account JSON is for server-side admin SDK calls (from Firebase Console → Project Settings → Service accounts → "Generate new private key").
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Paste the full JSON content (one line) or base64-encode if multiline is awkward.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- App identity ---
APP_URL=http://localhost:3000
# The single email permitted to sign in (single-user allowlist).
ALLOWED_EMAIL=
