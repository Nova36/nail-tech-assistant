# Canonical app URL
APP_URL=http://localhost:3000

# Single-user allowlist
ALLOWED_EMAIL=

# Pinterest
PINTEREST_ACCESS_TOKEN=

# Dev-only Pinterest mock mode (NEVER set in production — guard checks NODE_ENV).
# When set, lib/pinterest/client.ts short-circuits real API calls and returns
# fixture data from lib/pinterest/__fixtures__/boards.ts so /pinterest can be
# demoed locally without hitting Pinterest. Acceptable values:
#   ok                 — verify ok + 12-board paginated mock (covers infinite scroll)
#   invalid_token     — verify returns 401 → minimal placeholder branch
#   insufficient_scope — verify returns 403 → minimal placeholder branch
#   network            — verify returns network error
# If using mock mode, you can set PINTEREST_ACCESS_TOKEN to any non-empty
# string (e.g. "mock-dev-token") just to satisfy env validation.
# PINTEREST_MOCK=ok

# Firebase public client config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin config — EITHER:
#   (a) Paste the whole service-account JSON as one line here (preferred for
#       hosting configs — no PEM newline-escaping hassle), OR
#   (b) Leave this blank and fill the split triplet below.
# The split triplet takes precedence if both forms are provided.
#
# This same service account is also used for Vertex AI (Gemini image gen).
# The Firebase Admin SDK service account on `nail-tech-assistant` has been
# granted `roles/aiplatform.user`, so one credential serves both backends.
# See `scripts/spike/gemini-spike.mjs` for the call-site reference.
FIREBASE_SERVICE_ACCOUNT_JSON=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
