# Canonical app URL
APP_URL=http://localhost:3000

# Single-user allowlist
ALLOWED_EMAIL=

# Pinterest
PINTEREST_ACCESS_TOKEN=

# Firebase public client config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin config — EITHER:
#   (a) Paste the whole service-account JSON as one line here (preferred for
#       hosting configs — no PEM newline-escaping hassle), OR
#   (b) Leave this blank and fill the split triplet below.
# The split triplet takes precedence if both forms are provided.
FIREBASE_SERVICE_ACCOUNT_JSON=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
